{% for author in authors %}
<div class="col">
    <div class="card h-100">
        <div class="card-body">
            <h5 class="card-title">
                <a href="{{ path('author_show', {id: author.id}) }}">{{ author.name }}</a>
            </h5>
            <p class="card-text">
                <small class="text-muted">{{ author.lifespan }}</small>
            </p>
            <p class="card-text">
                <small>Книг: {{ author.books|length }}</small>
            </p>
            
            {% if author.books|length > 0 %}
            <div class="author-books" data-author-id="{{ author.id }}" data-limit="3">
                {% for book in author.books|slice(0, 3) %}
                <div class="d-flex align-items-center mb-2">
                    {% if book.imageName %}
                        <img src="{{ book.imageLink ?: '/uploads/books_covers/' ~ book.imageName }}" class="img-thumbnail me-2" alt="{{ book.title }}" style="width: 40px; height: 50px; object-fit: contain;">
                    {% elseif book.imageLink %}
                        <img src="{{ book.imageLink }}" class="img-thumbnail me-2" alt="{{ book.title }}" style="width: 40px; height: 50px; object-fit: contain;">
                    {% else %}
                        <div class="bg-light text-dark d-flex align-items-center justify-content-center me-2 rounded" style="width: 40px; height: 50px;">
                            <small>Нет</small>
                        </div>
                    {% endif %}
                    <a href="{{ path('book_show', {id: book.id}) }}" class="text-decoration-none small">{{ book.title }}</a>
                </div>
                {% endfor %}
                
                {% if author.books|length > 3 %}
                <div class="text-center mt-2">
                    <button class="btn btn-sm btn-outline-secondary load-more-author-books" data-author-id="{{ author.id }}">
                        <i class="bi bi-chevron-down"></i> Ещё {{ author.books|length - 3 }}
                    </button>
                </div>
                {% endif %}
            </div>
            {% endif %}
        </div>
    </div>
</div>
{% endfor %}
