{% extends 'base.html.twig' %}

{% block body %}
<h1>{% if author %}Редактирование автора{% else %}Добавление автора{% endif %}</h1>

<form method="post" class="row g-3">
    {% if author %}
    <input type="hidden" name="_token" value="{{ csrf_token('edit' ~ author.id) }}">
    {% endif %}
    
    <div class="col-12">
        <label for="name" class="form-label">Имя</label>
        <input type="text" class="form-control" id="name" name="name" value="{{ author.name|default('') }}" required>
    </div>
    
    <div class="col-md-6">
        <label for="birth_year" class="form-label">Год рождения</label>
        <input type="number" class="form-control" id="birth_year" name="birth_year" value="{{ author.birthYear|default('') }}">
    </div>
    
    <div class="col-md-6">
        <label for="death_year" class="form-label">Год смерти</label>
        <input type="number" class="form-control" id="death_year" name="death_year" value="{{ author.deathYear|default('') }}">
    </div>
    
    <div class="col-12">
        <label for="biography" class="form-label">Биография</label>
        <textarea class="form-control" id="biography" name="biography" rows="8">{{ author.biography|default('') }}</textarea>
    </div>
    
    <div class="col-12">
        <button type="submit" class="btn btn-primary">Сохранить</button>
        {% if author %}
            <a href="{{ path('author_show', {id: author.id}) }}" class="btn btn-outline-secondary">Отмена</a>
        {% else %}
            <a href="{{ path('author_index') }}" class="btn btn-outline-secondary">Отмена</a>
        {% endif %}
    </div>
</form>
{% endblock %}
