{% extends 'base.html.twig' %}

{% block body %}
<div class="row">
    <div class="col-md-4">
        {% if book.imageName %}
            <img src="{{ book.imageLink ?: '/uploads/books_covers/' ~ book.imageName }}" class="img-fluid rounded" alt="{{ book.title }}">
        {% elseif book.imageLink %}
            <img src="{{ book.imageLink }}" class="img-fluid rounded" alt="{{ book.title }}">
        {% else %}
            <div class="bg-light text-dark d-flex align-items-center justify-content-center rounded" style="height: 300px;">
                <span>Нет обложки</span>
            </div>
        {% endif %}
    </div>
    <div class="col-md-8">
        <div class="d-flex justify-content-between align-items-start">
            <h1>{{ book.title }}</h1>
            {% if is_granted('ROLE_ADMIN') %}
                <div class="btn-group" role="group">
                    <a href="{{ path('book_edit', {id: book.id}) }}" class="btn btn-sm btn-outline-primary">Редактировать</a>
                    <form method="post" action="{{ path('book_delete', {id: book.id}) }}" class="d-inline" onsubmit="return confirm('Удалить книгу?');">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ book.id) }}">
                        <button type="submit" class="btn btn-sm btn-outline-danger">Удалить</button>
                    </form>
                </div>
            {% endif %}
        </div>
        
        <p><strong>Автор:</strong> 
            {% if book.author %}
                <a href="{{ path('author_show', {id: book.author.id}) }}">{{ book.author.name }}</a>
            {% else %}
                Неизвестен
            {% endif %}
        </p>
        
        {% if book.year %}
            <p><strong>Год издания:</strong> {{ book.year }}</p>
        {% endif %}
        
        {% if book.isbn %}
            <p><strong>ISBN:</strong> {{ book.isbn }}</p>
        {% endif %}
        
        {% if book.description %}
            <hr>
            <h4>Описание</h4>
            <p>{{ book.description }}</p>
        {% endif %}
        
        <a href="{{ path('book_index') }}" class="btn btn-outline-secondary mt-3">Назад к списку</a>
    </div>
</div>
{% endblock %}
